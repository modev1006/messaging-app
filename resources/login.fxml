<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<StackPane prefWidth="500" prefHeight="550" styleClass="auth-root"
           xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="client.controllers.LoginController">

    <VBox alignment="CENTER" maxWidth="400">
        <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>

        <!-- Card -->
        <VBox styleClass="auth-card" spacing="8" alignment="CENTER">

            <!-- Header -->
            <Label text="💬" style="-fx-font-size: 42px;"/>
            <Label text="Connexion" styleClass="auth-title"/>
            <Label text="Accédez à votre espace de messagerie" styleClass="auth-subtitle"/>

            <Region prefHeight="16"/>

            <!-- Username -->
            <VBox spacing="4" alignment="CENTER_LEFT">
                <Label text="NOM D'UTILISATEUR" styleClass="auth-label"/>
                <TextField fx:id="usernameField" promptText="Entrez votre pseudo" styleClass="auth-field" maxWidth="300"/>
            </VBox>

            <Region prefHeight="4"/>

            <!-- Password -->
            <VBox spacing="4" alignment="CENTER_LEFT">
                <Label text="MOT DE PASSE" styleClass="auth-label"/>
                <PasswordField fx:id="passwordField" promptText="Entrez votre mot de passe" styleClass="auth-field" maxWidth="300"/>
            </VBox>

            <!-- Error label -->
            <Label fx:id="errorLabel" text="" styleClass="auth-error"/>

            <Region prefHeight="8"/>

            <!-- Login Button -->
            <Button text="Se connecter" onAction="#onLogin" styleClass="auth-btn-primary" maxWidth="300" minHeight="42"/>

            <Region prefHeight="8"/>

            <!-- Separator -->
            <Separator styleClass="auth-divider" maxWidth="200"/>

            <!-- Register Link -->
            <HBox alignment="CENTER" spacing="4">
                <Label text="Pas encore de compte ?" styleClass="auth-subtitle"/>
                <Hyperlink text="S'inscrire" onAction="#onGoToRegister" styleClass="auth-link"/>
            </HBox>
        </VBox>
    </VBox>
</StackPane>
